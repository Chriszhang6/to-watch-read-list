# 环境模式：development / production
ENV=development

# ========== 认证配置 ==========
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_random_secret_key_here_change_on_heroku

# ========== 数据库 ==========
# 本地开发：SQLite
# DATABASE_URL=sqlite:///./app.db
#
# Heroku PostgreSQL：自动设置为 DATABASE_URL
# 如需本地 PostgreSQL：postgresql://user:password@localhost/dbname
DATABASE_URL=sqlite:///./app.db

# ========== 外部 API ==========
# YouTube API：https://console.cloud.google.com
# 留空时本地开发会使用 Mock 数据
YOUTUBE_API_KEY=

# ========== 邮件发送 (SendGrid) ==========
# 生产环境需要：https://sendgrid.com
# 留空时本地开发会打印重置链接到控制台
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# ========== 应用设置 ==========
# 本地开发时设为 true，使用 Mock 外部服务
USE_MOCK_EXTERNAL=true
